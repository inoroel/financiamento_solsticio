# =================================================================
# POSTGRESQL - CONFIGURAÇÃO LOCAL
# =================================================================
# Para desenvolvimento local com PostgreSQL local:
# Exemplo: postgresql://usuario:senha@localhost:5432/financiamento_solsticio
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/financiamento_solsticio

# Para usar Vercel Postgres (quando publicar na Vercel):
# Descomente e configure as variáveis abaixo:
# POSTGRES_URL=postgresql://user:password@host:port/database
# POSTGRES_PRISMA_URL=postgresql://user:password@host:port/database?pgbouncer=true
# POSTGRES_URL_NON_POOLING=postgresql://user:password@host:port/database

# =================================================================
# SERVIDOR
# =================================================================
PORT=3000
NODE_ENV=development

# =================================================================
# SEGURANÇA
# =================================================================
# Webhook Secret (OBRIGATÓRIO EM PRODUÇÃO)
# Gere um secret forte: openssl rand -hex 32
WEBHOOK_SECRET=desenvolvimento_local_secret_alterar_em_producao

# Validação mTLS - Certificado do Cliente (Banco do Brasil)
# Se true, exige que o BB envie certificado de cliente (mTLS)
# Se false ou não definido, valida se presente mas não exige
# BB_REQUIRE_CLIENT_CERT=true

# Ambiente do Banco do Brasil (sandbox ou production)
# Se não definido, usa NODE_ENV para determinar
# BB_ENVIRONMENT=production

# CORS - Origens permitidas (separadas por vírgula)
# Em desenvolvimento local, deixe vazio ou use * (já configurado no código)
# Em produção, defina: https://seu-dominio.com,https://www.seu-dominio.com
ALLOWED_ORIGINS=

# =================================================================
# NOTAS
# =================================================================
# 1. Em desenvolvimento local, o WEBHOOK_SECRET pode ser qualquer valor
# 2. Em produção, gere um secret forte e seguro
# 3. O ALLOWED_ORIGINS só é necessário em produção
# 4. Para PostgreSQL local, instale e configure PostgreSQL antes de iniciar
