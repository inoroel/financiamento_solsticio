# Variáveis de ambiente - Bilheteria Solstício
# Copie este arquivo para .env e preencha os valores

# Ambiente
NODE_ENV=development

# Porta do servidor (desenvolvimento local)
PORT=3001

# Banco de dados PostgreSQL
# Na Vercel, configure POSTGRES_URL no dashboard
POSTGRES_URL=postgres://usuario:senha@localhost:5432/bilheteria_solsticio

# JWT Secret (gere um valor único e forte para produção)
JWT_SECRET=sua-chave-secreta-jwt-muito-forte-aqui
JWT_EXPIRES_IN=7d

# CORS - Origens permitidas (separadas por vírgula)
# Em desenvolvimento, localhost é permitido automaticamente
# ALLOWED_ORIGINS=https://seu-site.com,https://www.seu-site.com

# Integração e-Rede (copiar do projeto original)
# REDE_PV=seu-pv
# REDE_TOKEN=seu-token
# REDE_ENVIRONMENT=sandbox
# REDE_CALLBACK_URL=https://seu-site.com/api/webhook/pagamento
